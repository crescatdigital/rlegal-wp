---
import { Image } from "astro:assets";
import { PhoneCall, MessagesSquare } from "@lucide/astro";

import reviewsIo from "/public/assets/reviews-io.png";
import googleReviews from "/public/assets/google-rating.png";
import legal500 from "/public/assets/legal-500.png";
import RequestCallback from "../../ui/RequestCallback.astro";
---

<section class="py-20 bg-white">
  <div class="mx-auto max-w-7xl px-6 lg:pl-[60px]">
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-[100px] items-start"
    >
      <!-- LEFT: FORM CARD -->
      <RequestCallback />

      <!-- RIGHT: CONTENT -->
      <div class="max-w-xl">
        <h2
          class="text-[32px] lg:text-[36px] font-semibold text-[#884A83] mb-6"
        >
          Clear, honest advice with a bespoke strategy for your case
        </h2>

        <!-- BULLETS -->
        <ul class="space-y-2 mb-[27px]">
          <li
            class="flex items-center gap-2 text-[22px] lg:text-[26px] text-[#000000]"
          >
            <span class="h-[22px] w-[22px] rounded-full bg-[#6D3B69]"></span>
            KEY USP 1
          </li>
          <li
            class="flex items-center gap-2 text-[22px] lg:text-[26px] text-[#000000]"
          >
            <span class="h-[22px] w-[22px] rounded-full bg-[#6D3B69]"></span>
            KEY USP 2
          </li>
          <li
            class="flex items-center gap-2 text-[22px] lg:text-[26px] text-[#000000] lg:mb-[40px]"
          >
            <span class="h-[22px] w-[22px] rounded-full bg-[#6D3B69]"></span>
            KEY USP 3
          </li>
        </ul>

        <!-- CTAS -->
        <div
          class="flex items-center justify-center lg:justify-start gap-2 mb-10"
        >
          <button
            type="button"
            class="inline-flex items-center lg:rounded-[15px] rounded-2xl
                 bg-[#4A884F] lg:px-4 px-3 py-2
                 lg:text-[18px] text-[16px] text-white
                 hover:bg-[#4A884F]"
          >
            <PhoneCall class="h-4 w-6 fill-white pr-2" /> 0207 038 3880
          </button>

          <button
            type="button"
            class="inline-flex items-center lg:rounded-[15px] rounded-2xl
                 bg-[#884A83] lg:px-4 px-3 py-2
                 lg:text-[18px] text-[16px] text-white
                 hover:bg-[#884A83]"
          >
            <MessagesSquare class="h-4 w-6 stroke-white pr-2" /> Free Consultation
          </button>
        </div>

        <!-- TRUST -->
        <div class="flex items-start gap-6">
          <Image
            src={legal500}
            alt="Legal 500"
            class="h-[110px] w-auto object-contain"
          />

          <div>
            <div class="flex items-center gap-3">
              <Image src={reviewsIo} alt="Reviews.io" class="h-[45px] w-auto" />
              <Image
                src={googleReviews}
                alt="Google Reviews"
                class="h-[63px] md:h-[78px] w-auto"
              />
            </div>

            <p class="text-[16px] text-[#000000] mt-1">
              Rated 4.9/5 from 515 verified reviews
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
