---
import Button from "../../ui/Button.astro";
const {
  title = "The RLegal Immigration Newsletter",
  subtitle = "Get the latest immigration law news, updates and advice straight to your inbox",
} = Astro.props;
---

<section class="bg-[#A3599D] py-6 max-h-[408px] hidden lg:block">
  <div class="mx-auto max-w-3xl px-6">
    <div class="flex flex-col items-center text-center gap-4">
      <!-- HEADING -->
      <h2 class="text-[32px] font-bold text-white mb-[34px]">
        {title}
      </h2>

      <!-- SUBTEXT -->
      <p class="text-[26px] text-[#FFFFFF] lg:w-[564px]">
        {subtitle}
      </p>

      <!-- FORM -->
      <form class="mt-4 flex flex-col items-center gap-4 w-[520px] max-w-md">
        <input
          type="email"
          required
          aria-label="Email address"
          class="w-full rounded-md px-4 py-2.5 text-sm
                 focus:outline-none focus:ring-2 focus:ring-white mb-[34px]"
        />

        <Button
          type="submit"
          class="rounded-md bg-[#4A884F] px-8 py-2.5 text-[22px] font-semibold text-white w-[265px] h-[58px]"
        >
          Sign Up
        </Button>
      </form>
    </div>
  </div>
</section>
