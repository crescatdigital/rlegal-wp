---
const {
    variant = "primary",
    size = "md",
    href,
    class: className,
    ...rest
} = Astro.props;

const variants: Record<string, string> = {
    primary: "bg-[#4A884F] text-white hover:bg-[#3d7242]",
    secondary: "bg-[#884A83] text-white hover:bg-[#7a4275]",
    outline:
        "border-2 border-[#884A83] text-[#884A83] hover:bg-[#884A83] hover:text-white",
    ghost: "bg-transparent text-[#884A83] hover:bg-slate-100",
};

const sizes: Record<string, string> = {
    sm: "px-4 py-2 text-[16px]",
    md: "px-4 py-2 text-[18px]",
    lg: "px-6 py-2.5 text-[22px]",
};

const Element = href ? "a" : "button";
---

<Element
    href={href}
    class:list={[
        "inline-flex items-center justify-center rounded-lg font-bold transition duration-200 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed",
        variants[variant],
        sizes[size],
        className,
    ]}
    {...rest}
>
    <slot />
</Element>
