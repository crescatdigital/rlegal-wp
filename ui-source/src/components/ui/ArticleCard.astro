---
import { Image } from "astro:assets";

const { title, excerpt, image, url = "#" } = Astro.props;
---

<div
  class="flex flex-col lg:flex-row
         w-full overflow-hidden rounded-md
         bg-[#F2F2F2]
         lg:h-[340px]"
>
  <!-- LEFT CONTENT -->
  <div
    class="w-full lg:w-[55%]
           bg-[#9A5B9D]
           border-l-0 lg:border-l-[10px]
           border-t-[10px] lg:border-t-0
           border-[#6D3B69]
           px-4 lg:px-[41px]
           py-6 lg:py-10
           text-white
           flex flex-col justify-between"
  >
    <!-- TEXT BLOCK -->
    <div>
      <h3 class="text-[22px] lg:text-[26px] font-semibold mb-2">
        {title}
      </h3>

      <p class="text-[16px] lg:text-[18px] leading-relaxed opacity-90">
        {excerpt}
      </p>
    </div>

    <!-- CTA -->
    <button
      class="mt-6 lg:mt-0
             inline-block w-fit lg:w-[260px]
             rounded-[15px]
             bg-[#6D3B69]
             px-4 py-2
             text-[16px] lg:text-[18px]
             text-white"
    >
      Read this article
    </button>
  </div>

  <!-- RIGHT IMAGE -->
  <div
    class="w-full lg:w-[45%]
           flex items-center justify-center
           bg-[#F2F2F2]
           py-6 lg:py-0"
  >
    <div
      class="h-[96px] w-[96px]
                 lg:h-[126px] lg:w-[135px]
                 flex items-center justify-center"
    >
      <svg
        class="h-full w-full text-[#B3B3B3]"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <rect x="3" y="3" width="18" height="18" rx="2"></rect>
        <circle cx="8.5" cy="8.5" r="1.5"></circle>
        <path d="M21 15l-5-5L5 21"></path>
      </svg>
    </div>
  </div>
</div>
