---
import { Image } from "astro:assets";

const {
  name,
  image,
  description,
  profileUrl = "#",
} = Astro.props;
---
<div class="bg-white rounded-md p-6 w-[260px] lg:w-[320px] lg:h-[550px] shadow-sm text-center">
  <!-- IMAGE -->
  <div class="mb-4">
    <Image
      src={image}
      alt={name}
      class="h-[140px] lg:h-[197px] w-full object-cover rounded-sm"
      loading="lazy"
    />
  </div>

  <!-- NAME -->
  <h4 class="text-[26px] font-semibold text-[#884A83] mb-2">
    {name}
  </h4>

  <!-- DESCRIPTION -->
  <p class="text-[18px] text-left leading-relaxed text-[#000000] mb-4">
    {description}
  </p>

  <!-- CTA -->
  <a
    href={profileUrl}
    class="inline-block lg:w-[220px] rounded-xl bg-[#884A83]
           px-4 py-1.5 mt-[16px] mb-[22px] text-[18px] font-medium text-white
           hover:bg-[#73366f] transition"
  >
    Find out more
  </a>
</div>