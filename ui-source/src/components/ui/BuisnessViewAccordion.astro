---
const { question, answer, open = false } = Astro.props;
---

<div class="overflow-hidden rounded-md" data-accordion>
  <!-- HEADER -->
  <button
    type="button"
    class={`accordion-trigger w-full flex items-center justify-between
            px-6 h-[85px]
            text-left text-[24px] lg:text-[30px] font-semibold text-white
            transition
            ${open ? "bg-[#6D3B69]" : "bg-[#6D3B69]/85 hover:bg-[#6D3B69]"}`}
    aria-expanded={open}
  >
    <span class="max-w-[90%]">{question}</span>

    <!-- ICON -->
    <span
      class="accordion-icon flex lg:h-[50px] lg:w-[50px] h-[30px] w-[30px] items-center justify-center
             bg-[#A3599D]
             rounded-full border border-white text-white text-sm lg:text-[24px]"
    >
      {open ? "↑" : "↓"}
    </span>
  </button>

  <!-- BODY (ALWAYS RENDERED) -->
  <div
    class={`accordion-content bg-white px-6 py-6
            text-[16px] lg:text-[18px] leading-[1.7] text-[#333333] space-y-4
            ${open ? "block" : "hidden"}`}
  >
    {answer.split("\n\n").map((p: any) => <p>{p}</p>)}
  </div>
</div>
