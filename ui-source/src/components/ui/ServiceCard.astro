---
const {
  title,
  variant = "business", 
} = Astro.props;
import { Image } from "astro:assets";
import arrowIcon from "/public/assets/Arrow.png";

const isBusiness = variant === "business";
---
<div class="overflow-hidden w-full max-w-[243px] shadow-sm mx-auto">

  <!-- IMAGE + TITLE AREA -->
  <div
    class={`relative bg-white h-[200px] px-4 pt-3 flex flex-col
      ${
        isBusiness
          ? "border-b border-[#6D3B69]"
          : "border-b border-[#A3599D]"
      }`}
  >
    <!-- Service title -->
    <span class="text-[24px] font-semibold text-[#884A83] mx-auto">
      {title}
    </span>

    <!-- Image placeholder -->
    <div class="flex-1 flex items-center justify-center">
      <div class="h-[114px] w-[114px] rounded-md flex items-center justify-center">
        <svg
          class="h-[90px] w-[90px] text-[#B3B3B3]"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <path d="M21 15l-5-5L5 21" />
        </svg>
      </div>
    </div>
  </div>

  <!-- FOOTER STRIP -->
  <div
    class={`h-[33px] px-4 flex items-center justify-end
      ${
        isBusiness
          ? "bg-[#6D3B69] text-white"
          : "bg-[#A3599D] text-white"
      }`}
  >
   <Image
  src={arrowIcon}
  alt="Arrow"
  class="w-[34px] h-[34px] object-contain"
/>

  </div>
</div>